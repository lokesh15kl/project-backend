# Database (MongoDB)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/career_db?retryWrites=true&w=majority

# Legacy SQL variables (unused after MongoDB migration)
# JDBC_DATABASE_URL=jdbc:mysql://<HOST>:3306/<DB_NAME>?useSSL=true&allowPublicKeyRetrieval=true
# DATABASE_URL=
# DATABASE_USERNAME=<DB_USER>
# DATABASE_PASSWORD=<DB_PASS>

# SMTP (OTP email)
SMTP_USERNAME=<YOUR_EMAIL>
SMTP_PASSWORD=<YOUR_APP_PASSWORD>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Optional AI key
HUGGINGFACE_API_KEY=
# Optional Hugging Face text generation endpoint
# Example: https://api-inference.huggingface.co/models/mistralai/Mistral-7B-Instruct-v0.2
HUGGINGFACE_TEXT_MODEL_URL=

# Frontend origins allowed for CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://lokesh15kl.github.io

# Required for frontend hosted on a different domain
SESSION_COOKIE_SAME_SITE=None
SESSION_COOKIE_SECURE=true