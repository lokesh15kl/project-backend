# Copy this file to .env.local and fill in real values.
# This file is safe to commit; .env.local is ignored.

# Database
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/career_db?retryWrites=true&w=majority

# Legacy SQL variables (unused after MongoDB migration)
# JDBC_DATABASE_URL=jdbc:mysql://localhost:3306/full_project?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
# DATABASE_USERNAME=root
# DATABASE_PASSWORD=your_mysql_password

# SMTP (Gmail App Password, not regular account password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password

# Optional
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=5

# Optional Java override (if JAVA_HOME is not already set globally)
# JAVA_HOME=C:\Program Files\Java\jdk-21
